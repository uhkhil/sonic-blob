{
  "manifest_version": 3,
  "name": "Sonic Blob",
  "version": "1.0.0",
  "description": "A music visualiser.",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Sonic Blob"
  },
  "permissions": [
    "tabCapture",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
